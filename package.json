{
  "name": "meicento-claude-code-terminal-hud",
  "version": "2.0.0",
  "description": "3-line status HUD for Claude Code with rate limits, transcript parsing, and git status.",
  "main": "src/index.ts",
  "bin": {
    "meicento-hud": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "setup": "npx tsx scripts/setup.ts"
  },
  "keywords": [
    "claude-code",
    "hud",
    "status-line",
    "terminal",
    "rate-limits",
    "transcript"
  ],
  "author": "meicento",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
